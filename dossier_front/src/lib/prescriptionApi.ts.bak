// Récupération des prescriptions actives (pour l'affichage "en cours")

// Récupération de toutes les prescriptions (pour l'historique)
export async function getPrescriptionsPatient(patientId: string) {
  const response = await api.get(`/patients/${patientId}/prescriptions`);
  return response.data;
}

// Terminer une prescription
export async function terminerPrescription(id: string, patientId: string) {
  const response = await api.patch(`/patients/${patientId}/prescriptions/${id}/terminer`);
  return response.data;
}


